{
  "name": "github-repository-analytics",
  "private": true,
  "version": "1.0.0",
  "description": "GitHub Repository Analytics Dashboard — monorepo root",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n BACKEND,FRONTEND -c blue,magenta \"npm run dev --workspace backend\" \"npm run dev --workspace frontend\"",
    "dev:backend": "npm run dev --workspace backend",
    "dev:frontend": "npm run dev --workspace frontend",
    "build:frontend": "npm run build --workspace frontend",
    "start": "npm run start --workspace backend",
    "test": "npm run test --workspace backend",
    "migrate": "npm run migrate --workspace backend",
    "setup": "node scripts/setup-env.js"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
