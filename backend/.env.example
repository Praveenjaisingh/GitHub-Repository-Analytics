# ==============================
# App
# ==============================
PORT=5000
NODE_ENV=development
APP_URL=http://localhost:5000
CLIENT_URL=http://localhost:5173

# ==============================
# Database
# ==============================
# --- Local / Docker Postgres (used when DATABASE_URL is NOT set) ---
DB_DIALECT=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=github_analytics
DB_USER=postgres
DB_PASSWORD=postgres

# --- Supabase / Vercel production ---
# Get this from Supabase: Project Settings -> Database -> Connection string.
# For MIGRATIONS, use the direct connection (port 5432):
#   postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# For the DEPLOYED APP on Vercel, use the connection pooler instead (port 6543,
# "Transaction" mode) so serverless functions don't exhaust Supabase's
# connection limit:
#   postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# When DATABASE_URL is set, it takes priority over the DB_* vars above.
DATABASE_URL=
DB_SSL=true

# ==============================
# Redis (caching) - optional
# ==============================
# Local: redis://127.0.0.1:6379
# On Vercel, run Redis via a managed service reachable over TCP, e.g.
# Upstash Redis (https://upstash.com) - copy its "redis://" URL here.
# If left empty, the app transparently falls back to an in-memory cache.
REDIS_URL=

# ==============================
# Auth
# ==============================
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# GitHub OAuth App credentials (create one at https://github.com/settings/developers)
# Local dev callback:      http://localhost:5000/api/auth/github/callback
# Production callback:     https://<your-backend>.vercel.app/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:5000/api/auth/github/callback

# Personal access token used for higher unauthenticated-style rate limits
# when analyzing public repos without a logged-in user (optional but recommended)
GITHUB_TOKEN=

# ==============================
# Logging
# ==============================
LOG_LEVEL=info
